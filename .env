# ——— Google OAuth (Sign in with Google) ———
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/google/callback
#   https://YOUR_PRODUCTION_DOMAIN/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: signs OAuth state (CSRF). If unset, GOOGLE_CLIENT_SECRET is used for signing.

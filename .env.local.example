# Local Supabase (run: npm run supabase:start)
# Copy to .env.local and use as-is for local dev.

# Direct Postgres connection – used by Prisma migrate/generate (port 54322)
DIRECT_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# Runtime connection – used by the app (same URL for local)
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"

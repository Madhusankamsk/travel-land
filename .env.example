# Required for the app (Prisma + Next.js). Used by Docker Compose for the app service.
DATABASE_URL="postgresql://postgres:postgres@db:5432/postgres"
DIRECT_URL="postgresql://postgres:postgres@db:5432/postgres"
NODE_ENV="production"

# Optional: for local dev with Supabase CLI (npm run supabase:start), use:
# DIRECT_URL="postgresql://postgres:postgres@localhost:54322/postgres"
# DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# This app does NOT use Supabase JS client. Do not add NEXT_PUBLIC_SUPABASE_URL
# or NEXT_PUBLIC_SUPABASE_ANON_KEY to the app env — they are only for Supabase
# Studio (dashboard) and are set inside the studio service in docker-compose.

# Copy to `.env` and fill in values. Do not commit `.env`.

DATABASE_URL=
DIRECT_URL=

# ——— Google OAuth (Sign in with Google) ———
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/google/callback
#   https://YOUR_DOMAIN/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: dedicated secret for OAuth state signing. If unset, GOOGLE_CLIENT_SECRET is used.
# AUTH_SECRET=
# Optional (not required for the redirect-based Google button in the app).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ——— SMTP ———
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ——— Cloudinary (image/pdf uploads) ———
# Either set CLOUDINARY_URL, or set the 3 variables below.
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

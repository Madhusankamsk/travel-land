// Prisma schema for Supabase (PostgreSQL)
// https://pris.ly/d/supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // store bcrypt/hash only
  role      String   @default("user") // e.g. "admin", "user"
  is_active Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// TourStatus: UPCOMING = upcoming trips, ARCHIVED = past trips
enum TourStatus {
  UPCOMING
  ARCHIVED
}

model Tour {
  id                 String    @id @default(cuid())
  title              String
  status             TourStatus @default(UPCOMING)
  durationLabel       String    // e.g. "23–30 April 2026"
  heroImageUrl       String?
  introText          String    @db.Text
  basePrice          Decimal   @db.Decimal(10, 2) // Euro
  singleSupplement   Decimal?  @db.Decimal(10, 2)
  mandatoryInsurance String?   @db.Text
  optionalInsurance  String?   @db.Text
  depositLabel       String?   // Deposit
  balanceDeadline    String?   // Balance due
  included           String    @db.Text // Included in the price
  excluded           String    @db.Text // Not included in the price
  cancellationPolicy String?   @db.Text
  programPdfUrl      String?
  contactStaff       String?   // comma-separated: Eleonora,Sisira,Romeo
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  days               TourDay[]

  @@map("tours")
}

model TourDay {
  id          String @id @default(cuid())
  tourId      String
  tour        Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  order       Int    // 1-based day order
  dayHeading  String // e.g. "23 APRILE: Amman - Jerash"
  description String @db.Text // HTML rich text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tour_days")
}

// Prisma schema for Supabase (PostgreSQL)
// https://pris.ly/d/supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  /// Bcrypt hash; null when the account only uses Google OAuth (or legacy magic-link placeholder may still exist).
  password            String?
  /// Google OIDC "sub" — set when the user has signed in with Google at least once.
  googleSub           String?             @unique
  firstName           String?
  lastName            String?
  mobile              String?             @unique
  role                String              @default("user") // e.g. "admin", "user"
  is_active           Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  bookings            Booking[]
  membershipBookings  MembershipBooking[]

  @@map("users")
}

// TourStatus:
// - UPCOMING: published but not yet bookable
// - OPEN: accepting booking requests
// - SOLD_OUT: no availability
// - COMPLETED: trip is finished
enum TourStatus {
  UPCOMING
  OPEN
  SOLD_OUT
  COMPLETED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  DEPOSIT_PAID
  PAID
  COMPLETED
}

model Tour {
  id                 String    @id @default(cuid())
  title              String
  status             TourStatus @default(UPCOMING)
  // e.g. "23–30 April 2026"
  durationLabel       String
  // e.g. "7 days / 6 nights"
  durationDaysNights  String?

  // Optional marketing fields
  tripSubtitle        String?
  tripCode            String?  @unique

  // Destination fields
  destinationCountry  String?
  destinationCities   String? // comma-separated
  tripCategory        String?

  // Short summary / intro
  introText           String    @db.Text

  // Media
  heroImageUrl        String?
  galleryImageUrls    Json?
  tripVideoUrl        String?
  programPdfUrl       String?

  // Logistics
  startLocation       String?
  endLocation         String?
  meetingPoint        String?
  transportUsed       String?
  accommodationType   String?
  hotelCategory       String?
  roomType            String?

  // Group info
  minParticipants     Int?
  maxGroupSize        Int?
  ageRestrictions     String?
  difficultyLevel     String?
  requiresWalkingKmPerDay String?

  // Pricing
  basePrice          Decimal  @db.Decimal(10, 2)
  currency           String   @default("EUR")
  singleSupplement   Decimal? @db.Decimal(10, 2)

  // Deposit & deadline info
  depositLabel       String?
  balanceDeadline    String?
  bookingDeadline    String?
  availableSeats     Int?

  // Child pricing rules (free-text or structured string)
  childPolicy        String?  @db.Text

  // Insurance
  mandatoryInsurance String?  @db.Text
  optionalInsurance  String?  @db.Text

  // Included / excluded
  included           String   @db.Text
  excluded           String   @db.Text

  // Cancellation penalties (structured JSON; see data/cancellation-penalties-default.json)
  cancellationPenalties Json?

  // Contact
  contactStaffName   String?
  contactPhone        String?
  contactEmail        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  days               TourDay[]
  bookings           Booking[]

  @@map("tours")
}

model TourDay {
  id          String @id @default(cuid())
  tourId      String
  tour        Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  order       Int    // 1-based day order
  dayHeading  String // day title
  dateLabel   String?
  description String @db.Text // HTML rich text
  dayImageUrls Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tour_days")
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tourId    String
  tour      Tour          @relation(fields: [tourId], references: [id], onDelete: Cascade)
  status    BookingStatus @default(REQUESTED)
  reference String?       // e.g. "TL-8847" for display
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([userId, tourId])
  @@map("bookings")
}

// Travel Membership Form submissions (guest-first, save-after-login)
model MembershipBooking {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stored for backward compatibility with the legacy form.
  fullName String

  firstName String
  lastName  String

  dateOfBirth DateTime // stored as date; time part ignored
  address     String   @db.Text
  taxCode     String
  email       String

  telephone String @map("phone")

  packageName String // tour title or package name
  tourId      String? // optional link to Tour

  // Double | Double Shared | Single | Triple | Triple Shared
  roomType String

  baseQuota                               Decimal @db.Decimal(10, 2) @map("baseRate") // mapped from legacy "baseRate"
  mandatoryMedicalBaggageInsuranceAmount Decimal @db.Decimal(10, 2) @map("insuranceAmount") // mapped from legacy "insuranceAmount"
  supplementsVarious                      Decimal @db.Decimal(10, 2)
  travelCancellationInsuranceAmount      Decimal @db.Decimal(10, 2)
  registrationFee                         Decimal @db.Decimal(10, 2) @map("registrationFees") // mapped from legacy "registrationFees"
  totalQuota                              Decimal @db.Decimal(10, 2) @map("total") // mapped from legacy "total"

  // mapped from legacy flags used by the cancellation/privacy parts of the old form.
  declarationAccepted   Boolean @map("cancellationAccepted")
  dataProcessingAccepted Boolean @map("gdprAccepted")

  reference String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("membership_bookings")
}

// Magic-link tokens for SMTP-based passwordless login.
// Store only token hashes (never store the raw token) and enforce single-use.
model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("magic_link_tokens")
}

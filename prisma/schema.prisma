// Prisma schema for Supabase (PostgreSQL)
// https://pris.ly/d/supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  password            String              // store bcrypt/hash only
  firstName           String?
  lastName            String?
  mobile              String?             @unique
  role                String              @default("user") // e.g. "admin", "user"
  is_active           Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  bookings            Booking[]
  membershipBookings  MembershipBooking[]

  @@map("users")
}

// TourStatus: UPCOMING = upcoming trips, ARCHIVED = past trips
enum TourStatus {
  UPCOMING
  ARCHIVED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  DEPOSIT_PAID
  PAID
  COMPLETED
}

model Tour {
  id                 String    @id @default(cuid())
  title              String
  status             TourStatus @default(UPCOMING)
  durationLabel       String    // e.g. "23–30 April 2026"
  heroImageUrl       String?
  introText          String    @db.Text
  basePrice          Decimal   @db.Decimal(10, 2) // Euro
  singleSupplement   Decimal?  @db.Decimal(10, 2)
  mandatoryInsurance String?   @db.Text
  optionalInsurance  String?   @db.Text
  depositLabel       String?   // Deposit
  balanceDeadline    String?   // Balance due
  included           String    @db.Text // Included in the price
  excluded           String    @db.Text // Not included in the price
  cancellationPolicy String?   @db.Text
  programPdfUrl      String?
  contactStaff       String?   // comma-separated: Eleonora,Sisira,Romeo
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  days               TourDay[]
  bookings           Booking[]

  @@map("tours")
}

model TourDay {
  id          String @id @default(cuid())
  tourId      String
  tour        Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  order       Int    // 1-based day order
  dayHeading  String // e.g. "23 APRILE: Amman - Jerash"
  description String @db.Text // HTML rich text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tour_days")
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tourId    String
  tour      Tour          @relation(fields: [tourId], references: [id], onDelete: Cascade)
  status    BookingStatus @default(REQUESTED)
  reference String?       // e.g. "TL-8847" for display
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([userId, tourId])
  @@map("bookings")
}

// Travel Membership Form submissions (guest-first, save-after-login)
model MembershipBooking {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName            String
  dateOfBirth         DateTime // stored as date; time part ignored
  address             String   @db.Text
  taxCode             String
  email               String
  phone               String
  packageName         String   // tour title or package name
  tourId              String?  // optional link to Tour
  roomType            String   // Single | Double | Triple
  baseRate            Decimal  @db.Decimal(10, 2)
  insuranceAmount     Decimal  @db.Decimal(10, 2)
  registrationFees    Decimal  @db.Decimal(10, 2)
  total               Decimal  @db.Decimal(10, 2)
  gdprAccepted        Boolean
  cancellationAccepted Boolean
  reference           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("membership_bookings")
}

// Magic-link tokens for SMTP-based passwordless login.
// Store only token hashes (never store the raw token) and enforce single-use.
model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("magic_link_tokens")
}

// Prisma schema for Supabase (PostgreSQL)
// https://pris.ly/d/supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // store bcrypt/hash only
  role      String   @default("user") // e.g. "admin", "user"
  is_active Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

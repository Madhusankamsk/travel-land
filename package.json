{
  "name": "travel-land",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "media:migrate:cloudinary": "npx tsx scripts/migrate-assets-to-cloudinary.ts",
    "docker:up": "docker compose up -d",
    "docker:up:open": "docker compose up -d && node -e \"setTimeout(() => { require('child_process').execSync(process.platform === 'win32' ? 'start http://localhost:54323' : 'open http://localhost:54323', { stdio: 'inherit' }); }, 12000);\"",
    "docker:seed": "docker compose exec app npx prisma db seed"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
